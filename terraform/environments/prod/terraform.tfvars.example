project_id                   = "your-prod-project-id"
region                       = "asia-northeast1"
artifact_registry_repository = "backend"
cloud_run_service_name       = "gdgoc-backend-prod"
cloud_run_service_account_id = "gdgoc-backend-prod-run"
cloud_run_deletion_protection = true

cloudbuild_trigger_name = "gdgoc-backend-prod-trigger"
cloudbuild_filename     = "backend/cloudbuild.yaml"
cloudbuild_image        = "api"

github_owner        = "your-github-owner"
github_repo         = "GDGoC-Hackason"
github_branch_regex = "^main$"

cloud_sql_instance_name    = "gdgoc-backend-prod-sql"
cloud_sql_tier             = "db-custom-1-3840"
cloud_sql_disk_size_gb     = 50
cloud_sql_authorized_cidr  = "0.0.0.0/0"
cloud_sql_db_name          = "gdgoc"
cloud_sql_db_user          = "app_user"
cloud_sql_db_user_password = "replace-with-strong-password"

cloud_sql_deletion_protection = true

secret_debug               = "false"
secret_firebase_project_id = "your-firebase-project-id"
secret_gcs_bucket_name     = "your-gcs-bucket-name"
secret_google_places_api_key = "replace-google-places-api-key"
secret_gemini_api_key        = "replace-gemini-api-key"
