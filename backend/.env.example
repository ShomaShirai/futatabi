# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gdgoc

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Firebase ID token verification
FIREBASE_PROJECT_ID=your-firebase-project-id

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket-name

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACES_ENDPOINT=https://places.googleapis.com/v1/places:searchText
GOOGLE_PLACES_LANGUAGE_CODE=ja
GOOGLE_PLACES_REGION_CODE=JP

# Google Routes API
GOOGLE_DIRECTIONS_API_KEY=your-google-directions-api-key
GOOGLE_ROUTES_API_KEY=your-google-routes-api-key
GOOGLE_ROUTES_ENDPOINT=https://routes.googleapis.com/directions/v2:computeRoutes
GOOGLE_DIRECTIONS_ENDPOINT=https://maps.googleapis.com/maps/api/directions/json
GOOGLE_ROUTES_CONNECT_TIMEOUT_SECONDS=15
GOOGLE_ROUTES_READ_TIMEOUT_SECONDS=60

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.0-flash
